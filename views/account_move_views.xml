<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_reminder_form" model="ir.ui.view">
        <field name="name">account.move.reminder.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="days_overdue" readonly="1"
                       invisible="days_overdue == 0"/>
                <field name="reminder_level" readonly="1"
                       widget="badge"
                       decoration-warning="reminder_level == 'level_1'"
                       decoration-danger="reminder_level in ('level_2', 'level_3')"
                       invisible="reminder_level == 'none'"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_reminder_list" model="ir.ui.view">
        <field name="name">account.move.reminder.list</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_state']" position="after">
                <field name="days_overdue" optional="show"/>
                <field name="reminder_level" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
